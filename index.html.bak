<!-- ====== SERVICES ====== -->
<section class="services-section" id="services">
    <div class="section-watermark" style="top: 60px; right: -40px;">01</div>
    <div class="container">
        <div class="section-header split reveal">
            <div>
                <div class="section-eyebrow">01 &nbsp;Core Offerings</div>
                <h2 class="section-title">What We <em>Build</em></h2>
            </div>
            <div class="section-sub">Three deliberate systems, each designed to remove a specific bottleneck in your revenue engine. No bloat. No filler.</div>
        </div>
    </div>
    <div class="container">
        <div class="services-list">
            <div class="service-row reveal">
                <div class="service-num">01</div>
                <div class="service-name">Workflow Automation</div>
                <div class="service-desc">AI agents handle lead research, scoring, follow-ups, and CRM hygiene — continuously, without oversight.</div>
                <div class="service-tags"><span class="service-tag">CRM Automation</span><span class="service-tag">Lead Scoring</span><span class="service-tag">AI Assistant</span></div>
                <div class="service-arrow">&rarr;</div>
            </div>
            <div class="service-row reveal reveal-d1">
                <div class="service-num">02</div>
                <div class="service-name">Outbound Acceleration</div>
                <div class="service-desc">Multi-channel campaigns across email, LinkedIn, and voice — coordinated by AI and optimized in real time.</div>
                <div class="service-tags"><span class="service-tag">Email</span><span class="service-tag">LinkedIn</span><span class="service-tag">Cold Calling</span></div>
                <div class="service-arrow">&rarr;</div>
            </div>
            <div class="service-row reveal reveal-d2">
                <div class="service-num">03</div>
                <div class="service-name">Custom Growth Systems</div>
                <div class="service-desc">End-to-end GTM infrastructure: strategy, tech stack, processes, documentation, and ongoing optimization.</div>
                <div class="service-tags"><span class="service-tag">GTM Strategy</span><span class="service-tag">Custom AI</span><span class="service-tag">Consulting</span></div>
                <div class="service-arrow">&rarr;</div>
            </div>
        </div>
    </div>
</section>

<!-- ====== PROCESS ====== -->
<section class="process-section" id="process">
    <div class="section-watermark" style="top: 80px; left: -20px;">02</div>
    <div class="container">
        <div class="section-header centered reveal">
            <div class="section-eyebrow">02 &nbsp;Methodology</div>
            <h2 class="section-title">How We <em>Deliver</em></h2>
            <p class="section-sub" style="margin-top: 16px;">A four-phase approach refined across dozens of engagements. Each step builds on the last.</p>
        </div>
    </div>
    <div class="process-grid">
        <div class="process-step reveal">
            <div class="process-num">01</div>
            <h3>Sales Audit</h3>
            <p>We map your current pipeline, identify every leak, and pinpoint exactly where automation will drive the highest return.</p>
            <div class="process-meta"><span>1-2 weeks</span><span>Stakeholder interviews</span></div>
        </div>
        <div class="process-step reveal reveal-d1">
            <div class="process-num">02</div>
            <h3>System Build</h3>
            <p>Custom AI workflows designed around your ICP, competitive landscape, and existing sales motion. Nothing off-the-shelf.</p>
            <div class="process-meta"><span>2-4 weeks</span><span>Workflow design</span></div>
        </div>
        <div class="process-step reveal reveal-d2">
            <div class="process-num">03</div>
            <h3>Integration</h3>
            <p>Seamless connection to HubSpot, Salesforce, Slack, and your entire tech stack. Zero disruption to daily operations.</p>
            <div class="process-meta"><span>1-2 weeks</span><span>API connections</span></div>
        </div>
        <div class="process-step reveal reveal-d3">
            <div class="process-num">04</div>
            <h3>Scaling</h3>
            <p>Continuous A/B testing, signal analysis, and optimization. We scale what wins and kill what doesn't — fast.</p>
            <div class="process-meta"><span>Ongoing</span><span>Performance analytics</span></div>
        </div>
    </div>
</section>

<!-- ====== TOOLS MARQUEE ====== -->
