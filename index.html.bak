<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DealGrowth — Autonomous Revenue Systems</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #5e6ad2;
            --primary-hover: #828fff;
            --primary-focus: #5e69d1;
            --primary-glow: rgba(94, 106, 210, 0.12);
            --on-primary: #ffffff;

            --canvas: #010102;
            --surface-1: #0f1011;
            --surface-2: #141516;
            --surface-3: #18191a;
            --surface-4: #191a1b;

            --ink: #f7f8f8;
            --ink-muted: #d0d6e0;
            --ink-subtle: #8a8f98;
            --ink-tertiary: #62666d;

            --hairline: #23252a;
            --hairline-strong: #34343a;
            --hairline-tertiary: #3e3e44;

            --success: #27a644;
            --success-dim: rgba(39, 166, 68, 0.1);

            --rounded-xs: 4px;
            --rounded-sm: 6px;
            --rounded-md: 8px;
            --rounded-lg: 12px;
            --rounded-xl: 16px;
            --rounded-pill: 9999px;

            --font-display: 'Inter', 'SF Pro Display', -apple-system, system-ui, sans-serif;
            --font-body: 'Inter', -apple-system, system-ui, sans-serif;
            --font-mono: 'JetBrains Mono', 'SF Mono', ui-monospace, monospace;

            --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
            --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
            --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        html {
            scroll-behavior: smooth;
            scrollbar-width: thin;
            scrollbar-color: var(--hairline-strong) var(--canvas);
        }
        html::-webkit-scrollbar { width: 5px; }
        html::-webkit-scrollbar-track { background: var(--canvas); }
        html::-webkit-scrollbar-thumb { background: var(--hairline-strong); border-radius: 3px; }
        html::-webkit-scrollbar-thumb:hover { background: var(--ink-tertiary); }

        body {
            font-family: var(--font-body);
            background: var(--canvas);
            color: var(--ink);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            overflow-x: hidden;
            cursor: auto;
        }

        ::selection { background: rgba(94, 106, 210, 0.25); color: var(--ink); }

        /* =====================================================================
         * LOADING SCREEN
         * ===================================================================== */
        .loader {
            position: fixed; inset: 0; z-index: 10000;
            background: var(--canvas);
            display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 24px;
            transition: opacity 0.8s var(--ease-out-expo), visibility 0.8s;
        }
        .loader.done { opacity: 0; visibility: hidden; pointer-events: none; }
        .loader-logo {
            font-family: var(--font-display); font-size: 24px; font-weight: 600;
            color: var(--ink); letter-spacing: -0.5px;
        }
        .loader-logo span { color: var(--primary); }
        .loader-bar {
            width: 120px; height: 2px; background: var(--hairline); border-radius: 1px; overflow: hidden;
        }
        .loader-bar-fill {
            width: 0; height: 100%; background: var(--primary);
            animation: loaderFill 1.2s var(--ease-out-expo) forwards;
        }
        @keyframes loaderFill {
            0% { width: 0; }
            40% { width: 60%; }
            100% { width: 100%; }
        }

        /* =====================================================================
         * SCROLL PROGRESS
         * ===================================================================== */
        .scroll-progress {
            position: fixed; top: 0; left: 0; height: 2px; z-index: 10001;
            background: linear-gradient(90deg, var(--primary), var(--primary-hover));
            width: 0%; transition: width 0.1s linear;
        }

        /* =====================================================================
         * GLOBAL TEXTURE
         * ===================================================================== */
        body::before {
            content: '';
            position: fixed; inset: 0; z-index: 9998; pointer-events: none; opacity: 0.022;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
            background-repeat: repeat; background-size: 128px 128px;
        }
        .grid-bg {
            position: fixed; inset: 0; z-index: 0; pointer-events: none;
            background-image:
                linear-gradient(to right, rgba(255,255,255,0.012) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(255,255,255,0.012) 1px, transparent 1px);
            background-size: 80px 80px;
            mask-image: radial-gradient(ellipse at 50% 0%, rgba(0,0,0,0.5) 0%, transparent 60%);
            -webkit-mask-image: radial-gradient(ellipse at 50% 0%, rgba(0,0,0,0.5) 0%, transparent 60%);
        }

        /* =====================================================================
         * AMBIENT GLOW ORBS
         * ===================================================================== */
        .ambient-orb {
            position: absolute; border-radius: 50%; pointer-events: none; z-index: 0;
            filter: blur(80px);
        }
        .ambient-orb-1 {
            width: 500px; height: 500px; top: -200px; right: -100px;
            background: radial-gradient(circle, rgba(94, 106, 210, 0.07) 0%, transparent 70%);
            animation: orbFloat1 20s ease-in-out infinite;
        }
        .ambient-orb-2 {
            width: 400px; height: 400px; bottom: 10%; left: -150px;
            background: radial-gradient(circle, rgba(94, 106, 210, 0.04) 0%, transparent 70%);
            animation: orbFloat2 25s ease-in-out infinite;
        }
        .ambient-orb-3 {
            width: 300px; height: 300px; top: 40%; right: 10%;
            background: radial-gradient(circle, rgba(130, 143, 255, 0.03) 0%, transparent 70%);
            animation: orbFloat3 18s ease-in-out infinite;
        }
        @keyframes orbFloat1 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(-30px, 40px) scale(1.1); }
            66% { transform: translate(20px, -20px) scale(0.95); }
        }
        @keyframes orbFloat2 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(40px, -30px) scale(1.15); }
        }
        @keyframes orbFloat3 {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(-20px, 30px); }
        }

        /* =====================================================================
         * FLOATING GEOMETRIC ELEMENTS
         * ===================================================================== */
        .floater {
            position: absolute; pointer-events: none; z-index: 0;
            opacity: 0.035; border: 1px solid var(--ink);
        }
        .floater-1 { width: 40px; height: 40px; top: 20%; right: 10%; animation: float 8s ease-in-out infinite; }
        .floater-2 { width: 24px; height: 24px; top: 60%; left: 5%; border-radius: 50%; animation: float 10s ease-in-out infinite 2s; }
        .floater-3 { width: 60px; height: 1px; top: 40%; right: 20%; animation: float 12s ease-in-out infinite 1s; }
        .floater-4 { width: 16px; height: 16px; bottom: 20%; right: 15%; border-radius: 50%; animation: float 9s ease-in-out infinite 3s; }
        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
        }

        /* =====================================================================
         * HERO BACKGROUND — Rich layered atmosphere
         * ===================================================================== */
        .hero-bg-mesh {
            position: absolute; inset: 0; z-index: 0; pointer-events: none; overflow: hidden;
        }
        .mesh-blob {
            position: absolute; border-radius: 50%; filter: blur(100px); opacity: 0;
            animation: meshFadeIn 2s var(--ease-out-expo) 1s forwards;
        }
        .mesh-blob-1 {
            width: 600px; height: 600px; top: -10%; right: -5%;
            background: radial-gradient(circle, rgba(94, 106, 210, 0.12) 0%, transparent 60%);
            animation: meshFadeIn 2s var(--ease-out-expo) 1s forwards, meshDrift1 25s ease-in-out infinite 3s;
        }
        .mesh-blob-2 {
            width: 500px; height: 500px; bottom: -5%; left: -10%;
            background: radial-gradient(circle, rgba(130, 143, 255, 0.07) 0%, transparent 60%);
            animation: meshFadeIn 2s var(--ease-out-expo) 1.2s forwards, meshDrift2 20s ease-in-out infinite 3s;
        }
        .mesh-blob-3 {
            width: 400px; height: 400px; top: 40%; left: 30%;
            background: radial-gradient(circle, rgba(94, 106, 210, 0.05) 0%, transparent 60%);
            animation: meshFadeIn 2s var(--ease-out-expo) 1.4s forwards, meshDrift3 22s ease-in-out infinite 3s;
        }
        @keyframes meshFadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes meshDrift1 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(-40px, 30px) scale(1.1); }
            66% { transform: translate(20px, -20px) scale(0.95); }
        }
        @keyframes meshDrift2 {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(30px, -40px) scale(1.15); }
        }
        @keyframes meshDrift3 {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(-25px, 20px); }
        }
        .hero-aurora {
            position: absolute; inset: 0; z-index: 0; pointer-events: none;
            background:
                radial-gradient(ellipse 80% 50% at 20% 40%, rgba(94, 106, 210, 0.04) 0%, transparent 50%),
                radial-gradient(ellipse 60% 40% at 80% 60%, rgba(130, 143, 255, 0.03) 0%, transparent 50%);
        }
        .hero-vignette {
            position: absolute; inset: 0; z-index: 0; pointer-events: none;
            background: radial-gradient(ellipse at center, transparent 0%, var(--canvas) 85%);
        }
        .hero-starfield {
            position: absolute; inset: 0; z-index: 0; pointer-events: none;
            background-image:
                radial-gradient(1.5px 1.5px at 20px 30px, rgba(255,255,255,0.15), transparent),
                radial-gradient(1px 1px at 50px 100px, rgba(255,255,255,0.1), transparent),
                radial-gradient(1.5px 1.5px at 130px 80px, rgba(255,255,255,0.12), transparent),
                radial-gradient(1px 1px at 200px 150px, rgba(255,255,255,0.08), transparent),
                radial-gradient(1.5px 1.5px at 300px 50px, rgba(255,255,255,0.1), transparent),
                radial-gradient(1px 1px at 350px 180px, rgba(255,255,255,0.06), transparent),
                radial-gradient(1.5px 1.5px at 450px 120px, rgba(255,255,255,0.1), transparent),
                radial-gradient(1px 1px at 80px 200px, rgba(255,255,255,0.08), transparent),
                radial-gradient(1.5px 1.5px at 250px 250px, rgba(255,255,255,0.12), transparent),
                radial-gradient(1px 1px at 400px 220px, rgba(255,255,255,0.06), transparent);
            background-repeat: repeat;
            background-size: 500px 300px;
            opacity: 0.6;
            animation: starfieldDrift 60s linear infinite;
        }
        @keyframes starfieldDrift {
            from { background-position: 0 0; }
            to { background-position: 500px 300px; }
        }

        /* =====================================================================
         * TYPE SYSTEM
         * ===================================================================== */
        .t-display-xl { font-family: var(--font-display); font-size: 80px; font-weight: 600; line-height: 1.05; letter-spacing: -3.0px; }
        .t-display-lg { font-family: var(--font-display); font-size: 56px; font-weight: 600; line-height: 1.10; letter-spacing: -1.8px; }
        .t-display-md { font-family: var(--font-display); font-size: 40px; font-weight: 600; line-height: 1.15; letter-spacing: -1.0px; }
        .t-headline { font-family: var(--font-display); font-size: 28px; font-weight: 600; line-height: 1.20; letter-spacing: -0.6px; }
        .t-card-title { font-family: var(--font-display); font-size: 22px; font-weight: 500; line-height: 1.25; letter-spacing: -0.4px; }
        .t-subhead { font-family: var(--font-display); font-size: 20px; font-weight: 400; line-height: 1.40; letter-spacing: -0.2px; }
        .t-body-lg { font-family: var(--font-body); font-size: 18px; font-weight: 400; line-height: 1.50; letter-spacing: -0.1px; }
        .t-body { font-family: var(--font-body); font-size: 16px; font-weight: 400; line-height: 1.50; letter-spacing: -0.05px; }
        .t-body-sm { font-family: var(--font-body); font-size: 14px; font-weight: 400; line-height: 1.50; letter-spacing: 0; }
        .t-caption { font-family: var(--font-body); font-size: 12px; font-weight: 400; line-height: 1.40; letter-spacing: 0; }
        .t-button { font-family: var(--font-body); font-size: 14px; font-weight: 500; line-height: 1.20; letter-spacing: 0; }
        .t-eyebrow { font-family: var(--font-mono); font-size: 11px; font-weight: 400; line-height: 1.30; letter-spacing: 0; }
        .t-mono { font-family: var(--font-mono); font-size: 13px; font-weight: 400; line-height: 1.50; letter-spacing: 0; }

        @media (max-width: 768px) {
            .t-display-xl { font-size: 40px; letter-spacing: -1.0px; }
            .t-display-lg { font-size: 36px; letter-spacing: -0.8px; }
            .t-display-md { font-size: 28px; letter-spacing: -0.6px; }
        }

        /* =====================================================================
         * CONTAINER
         * ===================================================================== */
        .container { max-width: 1140px; margin: 0 auto; padding: 0 40px; position: relative; z-index: 1; }
        @media (max-width: 768px) { .container { padding: 0 24px; } }

        /* =====================================================================
         * SECTION WATERMARKS
         * ===================================================================== */
        .section-watermark {
            position: absolute;
            font-family: var(--font-display);
            font-size: clamp(180px, 22vw, 320px);
            font-weight: 700;
            color: rgba(255,255,255,0.012);
            line-height: 1;
            letter-spacing: -10px;
            pointer-events: none;
            z-index: 0;
            user-select: none;
        }

        /* =====================================================================
         * NAVIGATION
         * ===================================================================== */
        nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            height: 64px;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 40px;
            transition: all 0.5s var(--ease-out-expo);
            border-bottom: 1px solid transparent;
        }
        nav.scrolled {
            background: rgba(1, 1, 2, 0.82);
            backdrop-filter: blur(24px) saturate(1.3);
            -webkit-backdrop-filter: blur(24px) saturate(1.3);
            border-bottom-color: var(--hairline);
        }
        nav .logo {
            display: flex; align-items: center; text-decoration: none;
            opacity: 0.9; transition: opacity 0.3s;
        }
        nav .logo:hover { opacity: 1; }
        .nav-links { display: flex; align-items: center; gap: 32px; list-style: none; }
        .nav-links a {
            font-size: 14px; font-weight: 400; color: var(--ink-subtle); text-decoration: none;
            position: relative; padding: 4px 0;
            transition: color 0.3s ease;
        }
        .nav-links a::after {
            content: ''; position: absolute; bottom: -2px; left: 0; width: 0; height: 1px;
            background: var(--primary); transition: width 0.4s var(--ease-out-expo);
        }
        .nav-links a:hover, .nav-links a.active { color: var(--ink); }
        .nav-links a:hover::after, .nav-links a.active::after { width: 100%; }
        .nav-right { display: flex; align-items: center; gap: 12px; }
        .hamburger { display: none; }

        .mobile-drawer {
            position: fixed; top: 0; right: 0; bottom: 0; width: 320px; z-index: 200;
            background: var(--surface-1); border-left: 1px solid var(--hairline);
            padding: 80px 32px 32px; display: flex; flex-direction: column; gap: 4px;
            transform: translateX(100%); transition: transform 0.6s var(--ease-out-expo);
        }
        .mobile-drawer.active { transform: translateX(0); }
        .mobile-drawer a { font-size: 18px; font-weight: 500; color: var(--ink-muted); text-decoration: none; padding: 12px 0; border-bottom: 1px solid var(--hairline); transition: color 0.2s, padding-left 0.4s var(--ease-out-expo); }
        .mobile-drawer a:hover { color: var(--ink); padding-left: 8px; }
        .mobile-drawer .btn { margin-top: 16px; justify-content: center; }
        .mobile-overlay {
            position: fixed; inset: 0; z-index: 150; background: rgba(0,0,0,0.6);
            opacity: 0; pointer-events: none; transition: opacity 0.5s ease;
            backdrop-filter: blur(4px);
        }
        .mobile-overlay.active { opacity: 1; pointer-events: auto; }

        @media (max-width: 768px) {
            nav { padding: 0 24px; height: 56px; }
            .nav-links, .nav-right { display: none; }
            .hamburger {
                display: flex; flex-direction: column; justify-content: center; gap: 5px;
                width: 32px; height: 32px; background: none; border: none; cursor: pointer; padding: 0; z-index: 250;
            }
            .hamburger span { display: block; width: 20px; height: 1.5px; background: var(--ink); transition: transform 0.4s var(--ease-out-expo), opacity 0.3s; }
            .hamburger.active span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
            .hamburger.active span:nth-child(2) { opacity: 0; }
            .hamburger.active span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
        }

        /* =====================================================================
         * BUTTONS
         * ===================================================================== */
        .btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 6px;
            font-family: var(--font-body); font-size: 14px; font-weight: 500;
            padding: 10px 18px; border: none; border-radius: var(--rounded-md);
            cursor: pointer; text-decoration: none; white-space: nowrap; position: relative; overflow: hidden;
            transition: background-color 0.2s, box-shadow 0.3s, transform 0.2s;
        }
        .btn-primary {
            background: var(--primary); color: var(--on-primary);
            box-shadow: 0 0 0 0 var(--primary-glow);
        }
        .btn-primary:hover { background: var(--primary-hover); box-shadow: 0 0 24px 4px var(--primary-glow); transform: translateY(-1px); }
        .btn-primary:active { background: var(--primary-focus); transform: translateY(0); }
        .btn-secondary { background: var(--surface-1); color: var(--ink); border: 1px solid var(--hairline); }
        .btn-secondary:hover { background: var(--surface-2); border-color: var(--hairline-strong); transform: translateY(-1px); }
        .btn-ghost { background: transparent; color: var(--ink-subtle); padding: 10px 0; }
        .btn-ghost:hover { color: var(--ink); }
        .btn-sm { padding: 6px 12px; font-size: 13px; }

        /* =====================================================================
         * HERO
         * ===================================================================== */
        .hero {
            min-height: 100vh; display: grid; grid-template-columns: 1.1fr 1fr;
            align-items: center; position: relative; z-index: 1; padding-top: 64px;
            overflow: hidden;
        }
        @media (max-width: 1024px) { .hero { grid-template-columns: 1fr; min-height: auto; padding-top: 80px; } }

        .hero-left { padding: 80px 40px 80px 40px; position: relative; z-index: 2; }
        @media (max-width: 1024px) { .hero-left { padding: 48px 24px 40px; } }

        .hero-eyebrow {
            display: inline-flex; align-items: center; gap: 10px;
            font-family: var(--font-mono); font-size: 11px; color: var(--primary);
            margin-bottom: 28px; padding: 6px 14px;
            background: rgba(94, 106, 210, 0.06);
            border: 1px solid rgba(94, 106, 210, 0.12);
            border-radius: var(--rounded-sm);
        }
        .hero-eyebrow .status-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: var(--success); box-shadow: 0 0 8px var(--success);
            animation: pulse-dot 2.5s ease-in-out infinite;
        }
        @keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

        .hero h1 {
            font-family: var(--font-display);
            font-size: clamp(42px, 5.5vw, 80px); font-weight: 600;
            line-height: 1.05; letter-spacing: -0.035em;
            color: var(--ink); margin-bottom: 28px; max-width: 560px;
        }
        .hero h1 em { font-style: normal; color: var(--primary); }

        .hero-desc {
            font-size: 18px; line-height: 1.7; color: var(--ink-muted);
            max-width: 460px; margin-bottom: 40px; font-weight: 400; letter-spacing: -0.1px;
        }
        .hero-actions { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }

        /* Scroll indicator */
        .scroll-indicator {
            position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
            display: flex; flex-direction: column; align-items: center; gap: 8px;
            opacity: 0.4; animation: scrollBounce 2s ease-in-out infinite;
        }
        .scroll-indicator span { font-size: 10px; color: var(--ink-subtle); letter-spacing: 0.1em; text-transform: uppercase; }
        .scroll-indicator .scroll-line { width: 1px; height: 32px; background: linear-gradient(to bottom, var(--ink-subtle), transparent); }
        @keyframes scrollBounce {
            0%, 100% { transform: translateX(-50%) translateY(0); }
            50% { transform: translateX(-50%) translateY(8px); }
        }
        @media (max-width: 1024px) { .scroll-indicator { display: none; } }

        .hero-right {
            padding: 40px 40px 40px 0; display: flex; align-items: center; justify-content: center;
            position: relative; min-height: 500px;
        }
        @media (max-width: 1024px) { .hero-right { padding: 0 24px 60px; min-height: 400px; } }

        /* =====================================================================
         * ORBITAL HERO VISUAL — Large, dynamic, takes up more space
         * ===================================================================== */
        .orbital-system {
            position: relative; width: 560px; height: 560px;
            perspective: 800px;
        }
        @media (max-width: 1024px) { .orbital-system { width: 480px; height: 480px; } }
        @media (max-width: 768px) { .orbital-system { width: 360px; height: 360px; } }

        .orbital-core {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 20px; height: 20px; border-radius: 50%;
            background: radial-gradient(circle at 30% 30%, var(--primary-hover), var(--primary));
            box-shadow:
                0 0 40px 12px rgba(94, 106, 210, 0.5),
                0 0 80px 30px rgba(94, 106, 210, 0.2),
                0 0 120px 50px rgba(94, 106, 210, 0.08);
            z-index: 10;
            animation: corePulse 3s ease-in-out infinite;
        }
        @keyframes corePulse {
            0%, 100% { box-shadow: 0 0 40px 12px rgba(94, 106, 210, 0.5), 0 0 80px 30px rgba(94, 106, 210, 0.2), 0 0 120px 50px rgba(94, 106, 210, 0.08); }
            50% { box-shadow: 0 0 50px 16px rgba(94, 106, 210, 0.6), 0 0 100px 40px rgba(94, 106, 210, 0.25), 0 0 140px 60px rgba(94, 106, 210, 0.12); }
        }

        .orbit-ring {
            position: absolute; top: 50%; left: 50%;
            border: 1px solid rgba(94, 106, 210, 0.12);
            border-radius: 50%; transform-style: preserve-3d;
        }
        .orbit-ring::before {
            content: ''; position: absolute; top: -3px; left: 50%; transform: translateX(-50%);
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--primary);
            box-shadow: 0 0 10px 3px rgba(94, 106, 210, 0.6);
        }

        .orbit-1 { width: 120px; height: 120px; margin: -60px 0 0 -60px; transform: rotateX(70deg) rotateZ(0deg); animation: orbitRotate1 10s linear infinite; }
        .orbit-2 { width: 220px; height: 220px; margin: -110px 0 0 -110px; transform: rotateX(65deg) rotateZ(45deg); animation: orbitRotate2 15s linear infinite; border-color: rgba(94, 106, 210, 0.1); }
        .orbit-2::before { width: 6px; height: 6px; background: var(--primary-hover); }
        .orbit-3 { width: 340px; height: 340px; margin: -170px 0 0 -170px; transform: rotateX(75deg) rotateZ(120deg); animation: orbitRotate3 20s linear infinite; border-color: rgba(94, 106, 210, 0.08); }
        .orbit-3::before { width: 5px; height: 5px; background: var(--ink-muted); opacity: 0.7; }
        .orbit-4 { width: 440px; height: 440px; margin: -220px 0 0 -220px; transform: rotateX(60deg) rotateZ(200deg); animation: orbitRotate4 28s linear infinite; border-color: rgba(94, 106, 210, 0.06); }
        .orbit-4::before { width: 4px; height: 4px; background: var(--ink-subtle); opacity: 0.5; }
        .orbit-5 { width: 520px; height: 520px; margin: -260px 0 0 -260px; transform: rotateX(72deg) rotateZ(280deg); animation: orbitRotate5 35s linear infinite; border-color: rgba(94, 106, 210, 0.04); }
        .orbit-5::before { width: 3px; height: 3px; background: var(--ink-tertiary); opacity: 0.3; }

        @keyframes orbitRotate1 { from { transform: rotateX(70deg) rotateZ(0deg); } to { transform: rotateX(70deg) rotateZ(360deg); } }
        @keyframes orbitRotate2 { from { transform: rotateX(65deg) rotateZ(45deg); } to { transform: rotateX(65deg) rotateZ(405deg); } }
        @keyframes orbitRotate3 { from { transform: rotateX(75deg) rotateZ(120deg); } to { transform: rotateX(75deg) rotateZ(480deg); } }
        @keyframes orbitRotate4 { from { transform: rotateX(60deg) rotateZ(200deg); } to { transform: rotateX(60deg) rotateZ(560deg); } }
        @keyframes orbitRotate5 { from { transform: rotateX(72deg) rotateZ(280deg); } to { transform: rotateX(72deg) rotateZ(640deg); } }

        .orbit-particle {
            position: absolute; border-radius: 50%;
            box-shadow: 0 0 8px 2px rgba(94, 106, 210, 0.4);
        }
        .op-1 { width: 4px; height: 4px; top: 25%; left: 15%; background: var(--primary); animation: particleFloat 5s ease-in-out infinite; }
        .op-2 { width: 3px; height: 3px; top: 75%; left: 80%; background: var(--primary-hover); animation: particleFloat 7s ease-in-out infinite 1s; }
        .op-3 { width: 3px; height: 3px; top: 10%; left: 60%; background: var(--ink-muted); animation: particleFloat 6s ease-in-out infinite 2s; }
        .op-4 { width: 4px; height: 4px; top: 85%; left: 25%; background: var(--primary); animation: particleFloat 8s ease-in-out infinite 0.5s; }
        .op-5 { width: 2px; height: 2px; top: 45%; left: 5%; background: var(--primary-hover); animation: particleFloat 9s ease-in-out infinite 1.5s; }
        .op-6 { width: 3px; height: 3px; top: 55%; left: 90%; background: var(--ink-subtle); animation: particleFloat 6s ease-in-out infinite 3s; }
        .op-7 { width: 2px; height: 2px; top: 15%; left: 40%; background: var(--primary); animation: particleFloat 10s ease-in-out infinite 2.5s; }
        .op-8 { width: 3px; height: 3px; top: 90%; left: 70%; background: var(--primary-hover); animation: particleFloat 7s ease-in-out infinite 0.8s; }

        @keyframes particleFloat {
            0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.5; }
            25% { transform: translate(8px, -12px) scale(1.2); opacity: 0.9; }
            50% { transform: translate(-5px, -20px) scale(1); opacity: 1; }
            75% { transform: translate(12px, -8px) scale(1.1); opacity: 0.7; }
        }

        .orbit-trail {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 480px; height: 480px;
            border-radius: 50%;
            border: 1px dashed rgba(94, 106, 210, 0.08);
            animation: trailRotate 40s linear infinite;
        }
        @keyframes trailRotate { from { transform: translate(-50%, -50%) rotate(0deg); } to { transform: translate(-50%, -50%) rotate(360deg); } }

        .orbit-label {
            position: absolute; font-family: var(--font-mono); font-size: 9px; color: var(--ink-tertiary);
            letter-spacing: 0.05em; pointer-events: none;
        }
        .ol-1 { top: 18%; left: 60%; }
        .ol-2 { bottom: 22%; right: 15%; }
        .ol-3 { top: 60%; left: 10%; }

        /* =====================================================================
         * STATS
         * ===================================================================== */
        .stats-row {
            position: relative; z-index: 1;
            border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline);
            background: linear-gradient(180deg, rgba(255,255,255,0.015) 0%, transparent 100%);
        }
        .stats-inner { display: grid; grid-template-columns: repeat(6, 1fr); }
        @media (max-width: 1024px) { .stats-inner { grid-template-columns: repeat(3, 1fr); } }
        @media (max-width: 480px) { .stats-inner { grid-template-columns: repeat(2, 1fr); } }

        .stat-item {
            padding: 36px 20px; position: relative; border-right: 1px solid var(--hairline);
            transition: background 0.4s ease;
        }
        .stat-item:last-child { border-right: none; }
        .stat-item:hover { background: rgba(255,255,255,0.012); }
        @media (max-width: 1024px) {
            .stat-item:nth-child(3) { border-right: none; }
            .stat-item:nth-child(n+4) { border-top: 1px solid var(--hairline); }
        }
        @media (max-width: 480px) {
            .stat-item { border-right: none; }
            .stat-item:nth-child(odd) { border-right: 1px solid var(--hairline); }
            .stat-item:nth-child(n+3) { border-top: 1px solid var(--hairline); }
        }
        .stat-value {
            font-family: var(--font-display); font-size: 34px; font-weight: 600;
            color: var(--ink); letter-spacing: -0.8px; line-height: 1; margin-bottom: 8px;
            background: linear-gradient(180deg, var(--ink) 0%, var(--ink-muted) 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .stat-label { font-family: var(--font-mono); font-size: 10px; color: var(--ink-subtle); letter-spacing: 0; font-weight: 400; }

        /* =====================================================================
         * SECTION HEADERS
         * ===================================================================== */
        .section-header { margin-bottom: 64px; padding-top: 140px; position: relative; }
        .section-header.split { display: grid; grid-template-columns: 1.2fr 1fr; gap: 80px; align-items: end; }
        .section-header.centered { max-width: 600px; }
        .section-eyebrow {
            font-family: var(--font-mono); font-size: 11px; font-weight: 400; color: var(--primary);
            margin-bottom: 20px; letter-spacing: 0; display: inline-flex; align-items: center; gap: 8px;
        }
        .section-eyebrow::before { content: '//'; color: var(--ink-tertiary); }
        .section-title {
            font-family: var(--font-display); font-size: clamp(36px, 4.5vw, 56px); font-weight: 600;
            line-height: 1.10; letter-spacing: -0.03em; color: var(--ink);
        }
        .section-title em { font-style: normal; color: var(--primary); }
        .section-sub { font-size: 17px; line-height: 1.7; color: var(--ink-muted); font-weight: 400; letter-spacing: -0.02px; }
        @media (max-width: 768px) {
            .section-header.split { grid-template-columns: 1fr; gap: 20px; }
            .section-header { padding-top: 80px; margin-bottom: 48px; }
        }

        /* =====================================================================
         * SERVICES
         * ===================================================================== */
        .services-section { position: relative; }
        .services-list { border-top: 1px solid var(--hairline); position: relative; z-index: 1; }
        .service-row {
            display: grid; grid-template-columns: 56px 1fr 1fr auto;
            gap: 32px; align-items: center; padding: 36px 0;
            border-bottom: 1px solid var(--hairline);
            transition: all 0.5s var(--ease-out-expo); position: relative;
        }
        .service-row::before {
            content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
            background: var(--primary); opacity: 0; transition: opacity 0.3s ease;
        }
        .service-row:hover { background: rgba(255,255,255,0.015); padding-left: 24px; padding-right: 24px; margin: 0 -24px; }
        .service-row:hover::before { opacity: 1; }
        .service-row:hover .service-name { color: var(--ink); }
        .service-row:hover .service-arrow { opacity: 1; transform: translateX(0); }
        .service-num { font-family: var(--font-mono); font-size: 13px; color: var(--ink-tertiary); font-weight: 300; }
        .service-name { font-family: var(--font-display); font-size: 26px; font-weight: 600; color: var(--ink-muted); letter-spacing: -0.5px; transition: color 0.3s ease; }
        .service-desc { font-size: 15px; line-height: 1.7; color: var(--ink-subtle); max-width: 380px; }
        .service-tags { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
        .service-tag {
            font-family: var(--font-mono); font-size: 10px; font-weight: 400; color: var(--ink-subtle);
            background: var(--surface-2); padding: 3px 10px; border-radius: var(--rounded-pill);
            border: 1px solid var(--hairline); white-space: nowrap; transition: all 0.2s;
        }
        .service-row:hover .service-tag { border-color: var(--hairline-strong); color: var(--ink-muted); }
        .service-arrow { opacity: 0; transform: translateX(-8px); transition: all 0.4s var(--ease-out-expo); color: var(--primary); font-size: 20px; }
        @media (max-width: 900px) {
            .service-row { grid-template-columns: 48px 1fr auto; }
            .service-tags { display: none; }
            .service-row:hover { padding-left: 16px; padding-right: 16px; margin: 0 -16px; }
        }
        @media (max-width: 600px) {
            .service-row { grid-template-columns: 1fr; gap: 12px; }
            .service-num { display: none; }
            .service-arrow { display: none; }
            .service-row:hover { padding-left: 0; padding-right: 0; margin: 0; }
        }

        /* =====================================================================
         * PROCESS
         * ===================================================================== */
        .process-section { position: relative; }
        .process-grid {
            display: grid; grid-template-columns: repeat(4, 1fr);
            border-top: 1px solid var(--hairline); position: relative; z-index: 1;
        }
        .process-step {
            padding: 56px 32px 48px; position: relative; border-right: 1px solid var(--hairline);
            transition: all 0.5s var(--ease-out-expo);
        }
        .process-step:last-child { border-right: none; }
        .process-step::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
            background: var(--primary); opacity: 0; transition: opacity 0.4s ease;
        }
        .process-step:hover { background: rgba(255,255,255,0.012); }
        .process-step:hover::before { opacity: 1; }
        .process-step:hover .process-num {
            background: linear-gradient(180deg, var(--primary) 0%, var(--primary-focus) 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .process-num {
            font-family: var(--font-display); font-size: 64px; font-weight: 700;
            letter-spacing: -2px; line-height: 1; margin-bottom: 28px; transition: all 0.4s ease;
            background: linear-gradient(180deg, var(--surface-3) 0%, var(--surface-1) 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .process-step h3 { font-family: var(--font-display); font-size: 22px; font-weight: 500; color: var(--ink); margin-bottom: 14px; letter-spacing: -0.3px; }
        .process-step p { font-size: 14px; line-height: 1.7; color: var(--ink-subtle); }
        .process-meta { margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--hairline); display: flex; gap: 12px; flex-wrap: wrap; }
        .process-meta span {
            font-family: var(--font-mono); font-size: 10px; color: var(--ink-tertiary);
            background: var(--surface-1); padding: 3px 8px; border-radius: var(--rounded-xs); border: 1px solid var(--hairline);
        }
        @media (max-width: 1024px) {
            .process-grid { grid-template-columns: repeat(2, 1fr); }
            .process-step:nth-child(2) { border-right: none; }
            .process-step:nth-child(n+3) { border-top: 1px solid var(--hairline); }
        }
        @media (max-width: 480px) {
            .process-grid { grid-template-columns: 1fr; }
            .process-step { border-right: none; border-bottom: 1px solid var(--hairline); padding: 40px 24px; }
            .process-step:last-child { border-bottom: none; }
            .process-num { font-size: 48px; }
        }

        /* =====================================================================
         * TOOLS MARQUEE
         * ===================================================================== */
        .tools-section { padding: 80px 0; position: relative; overflow: hidden; }
        .tools-label {
            text-align: center; font-family: var(--font-mono); font-size: 10px;
            color: var(--ink-tertiary); letter-spacing: 0.1em; text-transform: uppercase;
            margin-bottom: 32px;
        }
        .marquee-wrap { position: relative; }
        .marquee-wrap::before, .marquee-wrap::after {
            content: ''; position: absolute; top: 0; bottom: 0; width: 120px; z-index: 2; pointer-events: none;
        }
        .marquee-wrap::before { left: 0; background: linear-gradient(to right, var(--canvas), transparent); }
        .marquee-wrap::after { right: 0; background: linear-gradient(to left, var(--canvas), transparent); }
        .marquee-track { display: flex; width: max-content; animation: marquee 35s linear infinite; }
        .marquee-track:hover { animation-play-state: paused; }
        @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        .marquee-item {
            display: flex; align-items: center; gap: 8px;
            padding: 0 32px; white-space: nowrap;
            font-family: var(--font-mono); font-size: 13px; color: var(--ink-subtle);
            opacity: 0.5; transition: opacity 0.3s;
        }
        .marquee-item:hover { opacity: 1; }
        .marquee-dot { width: 4px; height: 4px; background: var(--hairline-strong); border-radius: 50%; }

        /* =====================================================================
         * BENEFITS GRID
         * ===================================================================== */
        .benefits-section { position: relative; }
        .benefits-grid {
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
            background: var(--hairline); position: relative; z-index: 1; margin-bottom: 140px;
        }
        .benefit-card {
            background: var(--canvas); padding: 44px 36px;
            transition: all 0.5s var(--ease-out-expo); position: relative; overflow: hidden;
        }
        .benefit-card:hover {
            background: var(--surface-1);
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        .benefit-card:hover .benefit-icon { color: var(--primary); border-color: var(--primary); }
        .benefit-card:hover .benefit-title { color: var(--ink); }
        .benefit-icon {
            width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
            border: 1px solid var(--hairline-strong); border-radius: var(--rounded-sm);
            margin-bottom: 24px; font-size: 16px; color: var(--ink-subtle);
            transition: all 0.4s var(--ease-out-expo);
        }
        .benefit-title { font-family: var(--font-display); font-size: 18px; font-weight: 600; color: var(--ink-muted); margin-bottom: 10px; letter-spacing: -0.2px; transition: color 0.3s; }
        .benefit-desc { font-size: 14px; line-height: 1.7; color: var(--ink-subtle); }
        @media (max-width: 900px) { .benefits-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 480px) { .benefits-grid { grid-template-columns: 1fr; } }

        /* =====================================================================
         * CASE STUDIES
         * ===================================================================== */
        .cases-section { position: relative; }
        .cases-grid {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
            background: var(--hairline); position: relative; z-index: 1; margin-bottom: 140px;
        }
        .case-card {
            background: var(--canvas); padding: 56px 48px;
            transition: all 0.5s var(--ease-out-expo); position: relative; overflow: hidden;
        }
        .case-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
            opacity: 0; transition: opacity 0.4s;
        }
        .case-card:hover { background: var(--surface-1); transform: translateY(-2px); box-shadow: 0 16px 48px rgba(0,0,0,0.3); }
        .case-card:hover::before { opacity: 1; }
        .case-card:hover .case-link { color: var(--primary); }
        .case-card:hover .case-logo-initial { border-color: var(--primary); color: var(--primary); box-shadow: 0 0 20px rgba(94, 106, 210, 0.12); }
        .case-card-header { display: flex; align-items: center; gap: 14px; margin-bottom: 32px; }
        .case-logo-initial {
            width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
            border: 1px solid var(--hairline-strong); border-radius: var(--rounded-sm);
            font-family: var(--font-mono); font-size: 15px; font-weight: 500; color: var(--ink-subtle);
            transition: all 0.4s var(--ease-out-expo);
        }
        .case-industry { font-family: var(--font-mono); font-size: 10px; color: var(--ink-tertiary); letter-spacing: 0.04em; font-weight: 400; text-transform: uppercase; }
        .case-company { font-family: var(--font-display); font-size: 26px; font-weight: 600; color: var(--ink); letter-spacing: -0.4px; margin-bottom: 20px; }
        .case-quote {
            font-size: 16px; line-height: 1.7; color: var(--ink-muted); margin-bottom: 28px;
            letter-spacing: -0.02px; position: relative; padding-left: 20px;
            border-left: 2px solid var(--hairline); transition: border-color 0.4s;
        }
        .case-card:hover .case-quote { border-left-color: var(--primary); }
        .case-link { font-size: 13px; font-weight: 500; color: var(--ink-subtle); text-decoration: none; transition: color 0.3s ease; display: inline-flex; align-items: center; gap: 4px; }
        .case-metrics { display: flex; gap: 48px; margin-top: 36px; padding-top: 28px; border-top: 1px solid var(--hairline); }
        .case-metric-v {
            font-family: var(--font-display); font-size: 30px; font-weight: 600; color: var(--ink);
            letter-spacing: -0.6px; line-height: 1.1;
            background: linear-gradient(180deg, var(--ink) 0%, var(--ink-muted) 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .case-metric-l { font-family: var(--font-mono); font-size: 10px; color: var(--ink-tertiary); letter-spacing: 0.04em; font-weight: 400; text-transform: uppercase; margin-top: 4px; }
        @media (max-width: 768px) { .cases-grid { grid-template-columns: 1fr; } .case-card { padding: 40px 28px; } }

        /* =====================================================================
         * TEAM — Bigger avatars
         * ===================================================================== */
        .team-section { position: relative; }
        .team-row {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
            background: var(--hairline); position: relative; z-index: 1; margin-bottom: 140px;
        }
        .team-card {
            background: var(--canvas); padding: 56px;
            display: flex; align-items: flex-start; gap: 36px;
            transition: all 0.5s var(--ease-out-expo); position: relative;
        }
        .team-card:hover { background: var(--surface-1); }
        .team-card:hover .team-avatar { transform: scale(1.05); border-color: var(--primary); }
        .team-card:hover .team-avatar img { filter: grayscale(0%); }
        .team-card:hover .team-social { color: var(--primary); }

        .team-avatar {
            width: 140px; height: 140px; border-radius: 50%; overflow: hidden;
            border: 2px solid var(--hairline-strong); flex-shrink: 0;
            transition: all 0.5s var(--ease-out-expo); position: relative;
        }
        .team-avatar::before {
            content: ''; position: absolute; inset: -5px; border-radius: 50%;
            border: 1px solid transparent; transition: border-color 0.4s;
        }
        .team-card:hover .team-avatar::before { border-color: var(--primary); }
        .team-avatar img {
            width: 100%; height: 100%; object-fit: cover; display: block;
            filter: grayscale(50%) contrast(1.05);
            transition: filter 0.5s ease;
        }
        .team-info { flex: 1; padding-top: 8px; }
        .team-name { font-family: var(--font-display); font-size: 26px; font-weight: 600; color: var(--ink); letter-spacing: -0.4px; margin-bottom: 6px; }
        .team-role { font-family: var(--font-mono); font-size: 11px; font-weight: 400; color: var(--primary); margin-bottom: 18px; }
        .team-bio { font-size: 15px; line-height: 1.7; color: var(--ink-subtle); margin-bottom: 20px; }
        .team-social { display: inline-flex; align-items: center; gap: 6px; color: var(--ink-tertiary); text-decoration: none; font-size: 13px; font-weight: 500; transition: color 0.3s; }

        @media (max-width: 900px) {
            .team-row { grid-template-columns: 1fr; }
            .team-card { padding: 40px 32px; flex-direction: column; align-items: center; text-align: center; }
            .team-avatar { width: 160px; height: 160px; }
            .team-info { padding-top: 0; }
        }

        /* =====================================================================
         * FAQ
         * ===================================================================== */
        .faq-section { position: relative; }
        .faq-list { border-top: 1px solid var(--hairline); position: relative; z-index: 1; }
        .faq-item {
            border-bottom: 1px solid var(--hairline); padding: 32px 0; cursor: pointer;
            transition: all 0.4s var(--ease-out-expo); position: relative;
        }
        .faq-item::before {
            content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
            background: var(--primary); opacity: 0; transition: opacity 0.3s;
        }
        .faq-item:hover { padding-left: 20px; padding-right: 20px; margin: 0 -20px; background: rgba(255,255,255,0.008); }
        .faq-item:hover::before { opacity: 1; }
        .faq-item:hover .faq-q { color: var(--ink); }
        .faq-q {
            display: flex; justify-content: space-between; align-items: center; gap: 24px;
            font-family: var(--font-display); font-size: 20px; font-weight: 500;
            color: var(--ink-muted); letter-spacing: -0.2px; line-height: 1.4; transition: color 0.3s;
        }
        .faq-toggle {
            display: flex; align-items: center; justify-content: center;
            width: 32px; height: 32px; flex-shrink: 0;
            border: 1px solid var(--hairline); border-radius: var(--rounded-sm);
            transition: all 0.3s var(--ease-out-expo); background: var(--surface-1);
        }
        .faq-toggle::before {
            content: '+'; font-size: 18px; line-height: 1; color: var(--ink-subtle);
            transition: all 0.3s var(--ease-out-expo); font-weight: 300;
        }
        .faq-item.active .faq-toggle::before { transform: rotate(45deg); color: var(--primary); }
        .faq-item.active .faq-toggle { border-color: var(--primary); background: rgba(94, 106, 210, 0.06); }
        .faq-item.active .faq-q { color: var(--ink); }
        .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.5s var(--ease-out-expo), margin-top 0.4s ease; }
        .faq-item.active .faq-a { max-height: 250px; margin-top: 20px; }
        .faq-a p { font-size: 15px; line-height: 1.7; color: var(--ink-subtle); max-width: 600px; }
        @media (max-width: 600px) {
            .faq-item:hover { padding-left: 12px; padding-right: 12px; margin: 0 -12px; }
            .faq-q { font-size: 18px; }
        }

        /* =====================================================================
         * CTA
         * ===================================================================== */
        .cta-section { position: relative; padding-bottom: 140px; }
        .cta-panel {
            background: var(--surface-1); border: 1px solid var(--hairline); border-radius: var(--rounded-lg);
            padding: 64px; display: flex; flex-direction: column; align-items: flex-start;
            position: relative; overflow: hidden;
            box-shadow: 0 0 0 1px rgba(0,0,0,0.3), 0 16px 48px rgba(0,0,0,0.3);
        }
        .cta-panel::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
        }
        .cta-panel::after {
            content: ''; position: absolute; top: -100px; right: -100px; width: 300px; height: 300px;
            border-radius: 50%; background: radial-gradient(circle, rgba(94, 106, 210, 0.07) 0%, transparent 70%);
            pointer-events: none;
        }
        .cta-panel .section-eyebrow { margin-bottom: 20px; }
        .cta-panel .section-title { font-size: clamp(32px, 4vw, 48px); font-weight: 600; line-height: 1.15; letter-spacing: -0.03em; margin-bottom: 16px; max-width: 520px; }
        .cta-panel p { font-size: 17px; color: var(--ink-subtle); line-height: 1.7; max-width: 460px; margin-bottom: 32px; }
        @media (max-width: 768px) { .cta-panel { padding: 40px 28px; } .cta-section { padding-bottom: 80px; } }

        /* =====================================================================
         * BACK TO TOP
         * ===================================================================== */
        .back-to-top {
            position: fixed; bottom: 32px; right: 32px; z-index: 90;
            width: 44px; height: 44px; border-radius: 50%;
            background: var(--surface-1); border: 1px solid var(--hairline);
            display: flex; align-items: center; justify-content: center;
            color: var(--ink-subtle); text-decoration: none; font-size: 18px;
            opacity: 0; transform: translateY(20px); pointer-events: none;
            transition: all 0.4s var(--ease-out-expo); cursor: pointer;
        }
        .back-to-top.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
        .back-to-top:hover { background: var(--surface-2); border-color: var(--hairline-strong); color: var(--ink); transform: translateY(-2px); }
        @media (max-width: 768px) { .back-to-top { bottom: 20px; right: 20px; } }

        /* =====================================================================
         * FOOTER — Premium multi-layer design
         * ===================================================================== */
        .footer-top-border {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--hairline-strong), var(--primary), var(--hairline-strong), transparent);
            position: relative; z-index: 1;
        }
        .footer-top-border::before {
            content: ''; position: absolute; top: -1px; left: 0; right: 0; height: 1px;
            background: linear-gradient(90deg, transparent, rgba(94, 106, 210, 0.3), transparent);
        }
        footer {
            padding: 100px 40px 40px;
            position: relative; z-index: 1;
            background: linear-gradient(180deg, rgba(255,255,255,0.005) 0%, transparent 50%);
        }
        .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 80px; }
        .footer-brand .logo {
            display: flex; align-items: center; text-decoration: none;
            margin-bottom: 20px;
        }
        .footer-brand .logo img { height: 32px; width: auto; opacity: 0.85; transition: opacity 0.3s; }
        .footer-brand .logo:hover img { opacity: 1; }
        .footer-brand p {
            font-size: 14px; color: var(--ink-subtle); line-height: 1.7;
            max-width: 300px; margin-bottom: 24px;
        }
        .footer-col h4 {
            font-family: var(--font-mono); font-size: 10px; font-weight: 400;
            color: var(--ink-tertiary); letter-spacing: 0.08em;
            margin-bottom: 24px; text-transform: uppercase;
        }
        .footer-col ul { list-style: none; }
        .footer-col li { margin-bottom: 12px; }
        .footer-col a {
            font-size: 14px; color: var(--ink-subtle); text-decoration: none;
            transition: all 0.2s; position: relative; display: inline-block;
        }
        .footer-col a::after {
            content: ''; position: absolute; bottom: -2px; left: 0; width: 0; height: 1px;
            background: var(--primary); transition: width 0.3s var(--ease-out-expo);
        }
        .footer-col a:hover { color: var(--ink); }
        .footer-col a:hover::after { width: 100%; }
        .footer-contact-info {
            margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--hairline);
        }
        .footer-contact-info p {
            font-size: 13px; color: var(--ink-subtle); line-height: 1.7;
        }
        .footer-contact-info a {
            color: var(--ink-muted); text-decoration: none; font-size: 13px;
            transition: color 0.2s;
        }
        .footer-contact-info a:hover { color: var(--primary); }
        .footer-bottom {
            display: flex; justify-content: space-between; align-items: center;
            margin-top: 80px; padding-top: 28px;
            border-top: 1px solid var(--hairline);
            font-family: var(--font-mono); font-size: 11px; color: var(--ink-tertiary);
        }
        .footer-social {
            display: flex; gap: 12px;
        }
        .footer-social a {
            width: 36px; height: 36px; border-radius: 50%;
            border: 1px solid var(--hairline); display: flex;
            align-items: center; justify-content: center;
            color: var(--ink-subtle); text-decoration: none;
            font-size: 13px; font-weight: 500;
            transition: all 0.3s var(--ease-out-expo);
        }
        .footer-social a:hover {
            border-color: var(--primary); color: var(--primary);
            background: rgba(94, 106, 210, 0.08); transform: translateY(-2px);
        }
        .footer-legal {
            display: flex; gap: 24px;
        }
        .footer-legal a {
            color: var(--ink-tertiary); text-decoration: none;
            transition: color 0.2s; font-size: 11px;
        }
        .footer-legal a:hover { color: var(--ink); }
        @media (max-width: 900px) {
            footer { padding: 60px 24px 32px; }
            .footer-grid { grid-template-columns: 1fr 1fr; gap: 48px; }
            .footer-brand { grid-column: 1 / -1; }
        }
        @media (max-width: 480px) {
            .footer-grid { grid-template-columns: 1fr; }
            .footer-bottom { flex-direction: column; gap: 20px; text-align: center; }
            .footer-legal { justify-content: center; }
        }

        /* =====================================================================
         * SCROLL REVEAL
         * ===================================================================== */
        .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.9s var(--ease-out-expo), transform 0.9s var(--ease-out-expo); }
        .reveal.visible { opacity: 1; transform: translateY(0); }
        .reveal-d1 { transition-delay: 0.08s; }
        .reveal-d2 { transition-delay: 0.16s; }
        .reveal-d3 { transition-delay: 0.24s; }
        .reveal-d4 { transition-delay: 0.32s; }

        /* =====================================================================
         * PARALLAX
         * ===================================================================== */
        .parallax-slow { will-change: transform; }
    </style>
</head>
